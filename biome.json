{
  "$schema": "https://biomejs.dev/schemas/2.4.14/schema.json",
  "assist": {
    "actions": {
      "source": {
        "organizeImports": {
          "level": "on",
          "options": {
            "groups": [
              ":NODE:",
              ":BLANK_LINE:",

              ":PACKAGE:",
              ":BLANK_LINE:",

              ["@/**", "!**/*.css", "!**/*.json", "!**/*.scss"],
              ":BLANK_LINE:",

              ["../**", "!**/*.css", "!**/*.json", "!**/*.scss"],
              ":BLANK_LINE:",

              ["./**", "!**/*.css", "!**/*.json", "!**/*.scss"],
              ":BLANK_LINE:",

              ["**/*.css", "**/*.scss"],
              ":BLANK_LINE:",

              "**/*.json"
            ]
          }
        },
        "useSortedAttributes": "on",
        "useSortedKeys": "on"
      }
    }
  },
  "css": {
    "parser": {
      "tailwindDirectives": true
    }
  },
  "files": {
    "ignoreUnknown": false,
    "includes": ["**", "!**/.next", "!**/node_modules", "!package.json"]
  },
  "formatter": {
    "attributePosition": "auto",
    "bracketSpacing": true,
    "enabled": true,
    "formatWithErrors": false,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineEnding": "lf",
    "lineWidth": 80,
    "useEditorconfig": true
  },
  "javascript": {
    "formatter": {
      "arrowParentheses": "always",
      "attributePosition": "auto",
      "bracketSameLine": false,
      "bracketSpacing": true,
      "jsxQuoteStyle": "double",
      "quoteProperties": "asNeeded",
      "quoteStyle": "double",
      "semicolons": "always",
      "trailingCommas": "all"
    }
  },
  "linter": {
    "enabled": true,
    "rules": {
      "a11y": {
        "noSvgWithoutTitle": "off"
      },
      "correctness": {
        "noPrivateImports": "error",
        "useExhaustiveDependencies": "error",
        "useImportExtensions": "error"
      },
      "nursery": {
        "useSortedClasses": {
          "fix": "safe",
          "level": "info",
          "options": {
            "functions": ["clsx", "cva", "tw", "classNames"]
          }
        }
      },
      "performance": {
        "noImgElement": "off"
      },
      "recommended": true,
      "style": {
        "noNonNullAssertion": "off",
        "useTemplate": "off"
      },
      "suspicious": {
        "noUnknownAtRules": {
          "level": "error",
          "options": {
            "ignore": ["tailwind"]
          }
        }
      }
    }
  },
  "vcs": { "clientKind": "git", "enabled": false, "useIgnoreFile": true }
}
