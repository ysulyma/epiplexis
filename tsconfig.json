{
  "compilerOptions": {
    "allowImportingTsExtensions": true,
    "allowJs": true,
    "esModuleInterop": true,
    "incremental": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "lib": ["dom", "dom.iterable", "esnext"],
    "module": "esnext",
    "moduleResolution": "bundler",
    "noEmit": true,
    "paths": {
      "@/*": ["./*"]
    },
    "plugins": [
      { "name": "next" },
      { "name": "no-private-imports" },
      {
        "name": "no-restricted-imports",
        "options": {
          "patterns": [
            {
              "group": ["next/*"],
              "importNamePattern": "Html",
              "message": "you probably want @/components/liqvid"
            },
            {
              "group": ["@react-three/drei/*"],
              "importNamePattern": "Html",
              "message": "import from @/components/liqvid"
            }
          ]
        }
      }
    ],
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": true,
    "target": "es2017"
  },
  "exclude": ["node_modules"],
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts"
  ]
}
